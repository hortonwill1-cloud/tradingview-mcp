{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "tradingview-mcp": {
      "command": "uv",
      "args": ["run", "tradingview-mcp"],
      "env": {
        "PYTHONPATH": "src"
      }
    }
  }
}
